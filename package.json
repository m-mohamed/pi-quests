{
  "name": "@m-mohamed/pi-quests",
  "version": "0.8.0",
  "description": "Validation-first quest orchestration for Pi",
  "type": "module",
  "files": [
    "bin",
    "benchmarks/__init__.py",
    "benchmarks/harbor/*.py",
    "benchmarks/harbor/*.ts",
    "benchmarks/harbor/README.md",
    "benchmarks/local/fixtures/docs-audit/README.md",
    "benchmarks/local/*.json",
    "benchmarks/local/*.ts",
    "benchmarks/shared.ts",
    "benchmarks/slopcodebench/__init__.py",
    "benchmarks/slopcodebench/*.ts",
    "benchmarks/slopcodebench/README.md",
    "benchmarks/slopcodebench/official-overlay/*.py",
    "benchmarks/slopcodebench/official-overlay/*.yaml",
    "docs/baseline-results.md",
    "docs/benchmark-card.md",
    "docs/methodology.md",
    "docs/quest-control.png",
    "docs/reproducibility.md",
    "src",
    "types",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "quests",
    "pi-coding-agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/m-mohamed/pi-quests.git"
  },
  "homepage": "https://github.com/m-mohamed/pi-quests#readme",
  "bugs": {
    "url": "https://github.com/m-mohamed/pi-quests/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "bin": {
    "quest-headless": "./bin/quest-headless.mjs"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "node --import tsx --test tests/*.test.js",
    "pack:check": "npm pack --dry-run",
    "benchmark:local": "node --import tsx benchmarks/local/run.ts",
    "benchmark:tbench:preflight": "node --import tsx benchmarks/harbor/preflight.ts",
    "benchmark:tbench:sample": "node --import tsx benchmarks/harbor/run.ts --dataset terminal-bench-sample@2.0 --run-mode sample",
    "benchmark:tbench:full": "node --import tsx benchmarks/harbor/run.ts --dataset terminal-bench@2.0 --run-mode full",
    "benchmark:slop:official": "node --import tsx benchmarks/slopcodebench/official-run.ts",
    "check": "npm run typecheck && npm run test && npm run pack:check",
    "prepublishOnly": "npm run check"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "dependencies": {
    "tsx": "^4.20.3"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.7.3"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "image": "https://raw.githubusercontent.com/m-mohamed/pi-quests/main/docs/quest-control.png"
  }
}
