{
  "name": "@m-mohamed/pi-quests",
  "version": "0.8.0",
  "description": "Structured quest orchestration for long-running coding work in Pi",
  "type": "module",
  "files": [
    "bin",
    "docs/quest-architecture.md",
    "docs/quest-control.png",
    "docs/tutorial.md",
    "src/agent-process-registry.ts",
    "src/agent-task-runner.ts",
    "src/control-panel.ts",
    "src/extension-core.ts",
    "src/headless-core.ts",
    "src/headless-runner-core.ts",
    "src/index.ts",
    "src/internal-mode.ts",
    "src/plan-core.ts",
    "src/profile-core.ts",
    "src/quest-headless.ts",
    "src/quest-internal-loader.ts",
    "src/quest-runtime-helpers.ts",
    "src/quest-ui-controller.ts",
    "src/runtime-core.ts",
    "src/state-core.ts",
    "src/state.ts",
    "src/telemetry-core.ts",
    "src/types.ts",
    "src/ui-core.ts",
    "src/utils.ts",
    "src/workers.ts",
    "src/workflows.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "quests",
    "pi-coding-agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/m-mohamed/pi-quests.git"
  },
  "homepage": "https://github.com/m-mohamed/pi-quests#readme",
  "bugs": {
    "url": "https://github.com/m-mohamed/pi-quests/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "bin": {
    "quest-headless": "./bin/quest-headless.mjs"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "node --import tsx --test tests/*.test.js",
    "pack:check": "npm pack --dry-run",
    "internal:benchmark:local": "PI_QUESTS_INTERNAL=1 node --import tsx benchmarks/local/run.ts",
    "internal:benchmark:tbench:integrity": "PI_QUESTS_INTERNAL=1 node --import tsx benchmarks/harbor/integrity.ts",
    "internal:benchmark:tbench:preflight": "PI_QUESTS_INTERNAL=1 node --import tsx benchmarks/harbor/preflight.ts",
    "internal:benchmark:tbench:sample": "PI_QUESTS_INTERNAL=1 node --import tsx benchmarks/harbor/run.ts --dataset terminal-bench-sample@2.0 --run-mode sample",
    "internal:benchmark:tbench:full": "PI_QUESTS_INTERNAL=1 node --import tsx benchmarks/harbor/run.ts --dataset terminal-bench@2.0 --run-mode full",
    "internal:benchmark:slop:official": "PI_QUESTS_INTERNAL=1 node --import tsx benchmarks/slopcodebench/official-run.ts",
    "check": "npm run typecheck && npm run test && npm run pack:check",
    "prepublishOnly": "npm run check"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "^0.66.1",
    "@mariozechner/pi-coding-agent": "^0.66.1",
    "@mariozechner/pi-tui": "^0.66.1",
    "@sinclair/typebox": "^0.34.49"
  },
  "dependencies": {
    "tsx": "^4.20.3"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "^0.66.1",
    "@mariozechner/pi-coding-agent": "^0.66.1",
    "@mariozechner/pi-tui": "^0.66.1",
    "@sinclair/typebox": "^0.34.49",
    "@types/node": "^24.3.0",
    "typescript": "^5.7.3"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "image": "https://raw.githubusercontent.com/m-mohamed/pi-quests/main/docs/quest-control.png"
  }
}
